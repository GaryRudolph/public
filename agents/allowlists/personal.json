    "deny": [
      "rm -rf /",
      "rm -rf /*",
      "rm -rf ~",
      "rm -rf ~/*",
      "rm -rf $HOME",
      "rm -rf $HOME/*",
      "sudo",
      "dd",
      "mkfs"
