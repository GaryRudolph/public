# Loaded for repos under ~/Projects/agerpoint/ via includeIf in the base gitconfig.
# Today: just stamps the right commit email. SSH still uses the shared key.
#
# To split agerpoint onto its own SSH key later, add here:
#   [url "git@github.com-agerpoint:"]
#       insteadOf = git@github.com:
# ...and a matching `Host github.com-agerpoint` stanza in ~/.ssh/config.
[user]
	email = grudolph@agerpoint.com
