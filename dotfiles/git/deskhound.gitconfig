# Loaded for repos under ~/Projects/deskhound/ via includeIf in the base gitconfig.
# Today: just stamps the right commit email. SSH still uses the shared key.
#
# To split deskhound onto its own SSH key later, add here:
#   [url "git@github.com-deskhound:"]
#       insteadOf = git@github.com:
# ...and a matching `Host github.com-deskhound` stanza in ~/.ssh/config.
[user]
	email = gary@deskhound.ai
