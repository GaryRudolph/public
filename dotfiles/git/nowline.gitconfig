# Loaded for repos under ~/Projects/nowline/ via includeIf in the base gitconfig.
# Today: just stamps the right commit email. SSH still uses the shared key.
#
# To split nowline onto its own SSH key later, add here:
#   [url "git@github.com-nowline:"]
#       insteadOf = git@github.com:
# ...and a matching `Host github.com-nowline` stanza in ~/.ssh/config.
[user]
	email = gary@nowline.io
